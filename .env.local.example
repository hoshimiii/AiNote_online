# .env.local.example — 本地开发示例
# 复制一份到 .env.local 并替换下面的 secret

# 应用地址（本地开发时）
NEXTAUTH_URL=http://localhost:3000

# Auth.js / NextAuth 所需的全局 secret（用于 JWT 加密等）
# 生成建议使用 32 字节以上的随机字符串，例如：
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=replace_me_with_generated_secret
# 兼容别名（可选）
AUTH_SECRET=${NEXTAUTH_SECRET}

# 数据库（视项目需要启用）
# SQLite 示例（本地开发）
# DATABASE_URL="file:./dev.db"

# OAuth provider 示例（如需社交登录）
# AUTH_GITHUB_ID=...
# AUTH_GITHUB_SECRET=...

# 说明：
# - 把本文件复制为 .env.local，并把 NEXTAUTH_SECRET 替换为生成的随机值。
# - 修改后重启开发服务器：`pnpm dev` 或 `npm run dev`。
